{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(AGENTS.md)",
      "Read(CLAUDE.md)",
      "Read(CONTRIBUTING.md)",
      "Read(README.md)",
      "Read(.gitignore)",
      "Read(skills/**)",
      "Read(capabilities/**)",
      "Read(docs/**)",
      "Read(templates/**)",
      "Read(hooks/**)",
      "Read(bin/**)",

      "Read(memory/**)",
      "Read(data/**)",
      "Read(config/**)",

      "Edit(memory/**)",
      "Write(memory/**)",
      "Edit(data/**)",
      "Write(data/**)",
      "Edit(config/**)",
      "Write(config/**)",

      "Edit(skills/**)",
      "Write(skills/**)",
      "Edit(capabilities/**)",
      "Write(capabilities/**)",
      "Edit(AGENTS.md)",
      "Edit(CLAUDE.md)",
      "Edit(CONTRIBUTING.md)",

      "Read(.mcp.json)",
      "Edit(.mcp.json)",
      "Write(.mcp.json)",
      "Bash(claude mcp *)",
      "Bash(bin/link-worktree-state)",
      "Bash(./bin/link-worktree-state)",
      "Bash(bash bin/link-worktree-state)",
      "Bash(ln -s *)",

      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cat memory/*)",
      "Bash(cat data/*)",
      "Bash(cat config/*)",
      "Bash(wc *)",
      "Bash(tail *)",
      "Bash(head *)",
      "Bash(date *)",
      "Bash(mkdir -p memory*)",
      "Bash(mkdir -p data*)",
      "Bash(mkdir -p config*)",
      "Bash(printf *)",

      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git stash*)",
      "Bash(git rev-parse*)",

      "Bash(gh pr create*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh issue create*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",

      "Bash(claude -p *)",
      "Bash(claude --bg *)",

      "mcp__slack__*",
      "mcp__atlassian__*",
      "mcp__jira__*",
      "mcp__linear__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/*.token)",
      "Read(**/*.secret)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(gh pr merge*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Bash|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/hooks/protect-secrets.sh"
          }
        ]
      }
    ]
  }
}
