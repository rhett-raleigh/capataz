#!/usr/bin/env bash
# capataz — the SINGLE entrypoint. Every trigger (Raycast, Slack, cron,
# CLI) calls this so behavior is identical everywhere. See docs/invocation.md.
#
# Secrets note: this script does NOT load .env into the agent's environment, so
# tokens can't leak into the agent's context. MCP servers hold their own
# credentials (keychain / their own config). See docs/secrets.md.
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT="$(cd "$(dirname "$SOURCE")/.." && pwd)"
cd "$ROOT"

# --- PATH fix -------------------------------------------------------------
# Raycast (and other GUI triggers) launch scripts with a minimal PATH, so
# claude/git/gh/python3 often aren't found even though they work in your shell.
# Restore the usual locations. Add yours here if a tool still isn't found
# (run `which claude` in your terminal to see where it lives).
export PATH="$HOME/.local/bin:$HOME/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

# Optional: if your tools live somewhere unusual, hardcode the dir here.
# export PATH="/your/custom/bin:$PATH"

unset ANTHROPIC_API_KEY

if ! command -v claude >/dev/null 2>&1; then
  echo "capataz: 'claude' not found on PATH. Run 'which claude' in your terminal and add its directory to the PATH line in bin/capataz." >&2
  exit 127
fi
# --------------------------------------------------------------------------

# --- Parse flags ----------------------------------------------------------
ASYNC=false
INTERACTIVE=false
while [[ "${1:-}" == -* ]]; do
  case "$1" in
    --async) ASYNC=true; shift ;;
    -i|--interactive) INTERACTIVE=true; shift ;;
    *) echo "capataz: unknown flag $1" >&2; exit 1 ;;
  esac
done

INPUT="$*"
if [ -z "${INPUT}" ]; then
  echo "usage: capataz [--async | -i] \"<slack link | ticket ref | instruction>\"" >&2
  exit 1
fi

PROMPT="Orchestrate this input: ${INPUT}"

if [ "$INTERACTIVE" = true ]; then
  exec claude "$PROMPT" --agent capataz --add-dir "$ROOT"
elif [ "$ASYNC" = true ]; then
  claude --bg -p "$PROMPT" --agent capataz --add-dir "$ROOT"
  "$ROOT/bin/capataz-log" run-async "input: ${INPUT} (backgrounded)" || true
else
  OUT="$(claude -p "$PROMPT" --agent capataz --add-dir "$ROOT" --output-format json)"

  SID="$(printf '%s' "$OUT" | python3 -c 'import sys,json;print(json.load(sys.stdin).get("session_id",""))' 2>/dev/null || true)"
  RES="$(printf '%s' "$OUT" | python3 -c 'import sys,json;print(json.load(sys.stdin).get("result",""))' 2>/dev/null || true)"

  mkdir -p data
  printf '%s\t%s\t%s\n' "$(date -u +%FT%TZ)" "${SID:-unknown}" "${INPUT}" >> data/sessions.log
  SUMMARY="$(printf '%s' "${RES:-no result captured}" | head -c 200)"
  "$ROOT/bin/capataz-log" run "input: ${INPUT} | session: ${SID:-unknown} | result: ${SUMMARY}" || true

  printf '%s\n' "${RES:-$OUT}"
  if [ -n "${SID}" ]; then
    echo ""
    echo "↳ session ${SID}"
    echo "  resume/inspect:  claude --resume ${SID}"
  fi
fi
