  <key>StandardOutPath</key>
  <string>__CAPATAZ_ROOT__/data/launchd/consolidate-memory.log</string>
  <key>StandardErrorPath</key>
  <string>__CAPATAZ_ROOT__/data/launchd/consolidate-memory.err</string>
