# Copy to .env and fill in locally. .env is gitignored — never commit it.
# These are examples; your skills decide which they actually need.

# --- Where the agent's private files live (defaults to repo-local dirs) ---
AGENT_MEMORY_DIR=./memory
AGENT_DATA_DIR=./data
AGENT_CONFIG_DIR=./config

# --- Optional: tokens used by direct-API skills (prefer MCPs where possible) ---
# LINEAR_API_KEY=
# JIRA_BASE_URL=
# JIRA_EMAIL=
# JIRA_API_TOKEN=
# GITHUB_TOKEN=

# --- Identity hint so the same engine behaves per-context ---
# AGENT_PROFILE=personal   # or: work
